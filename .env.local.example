# Create a Spotify Developer App and get these keys from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID="your_spotify_client_id_here"
SPOTIFY_CLIENT_SECRET="your_spotify_client_secret_here"

# NextAuth secret. Generate one using: openssl rand -base64 32
# or use any random strong string
NEXTAUTH_SECRET="your_nextauth_secret_here"

# The canonical URL of your site (required for NextAuth in production)
# In development, it defaults to http://127.0.0.1:3000
NEXTAUTH_URL="http://127.0.0.1:3000"

# DeepL API key, used only by the one-off Tribial question translation script.
# Get a free key (no card required) at https://www.deepl.com/pro-api ("DeepL API Free" plan).
# Free-tier keys end in ":fx" and call api-free.deepl.com instead of api.deepl.com.
DEEPL_API_KEY="your_deepl_api_key_here"
