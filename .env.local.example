# Create a Spotify Developer App and get these keys from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID="your_spotify_client_id_here"
SPOTIFY_CLIENT_SECRET="your_spotify_client_secret_here"

# NextAuth secret. Generate one using: openssl rand -base64 32
# or use any random strong string
NEXTAUTH_SECRET="your_nextauth_secret_here"

# The canonical URL of your site (required for NextAuth in production)
# In development, it defaults to http://127.0.0.1:3000
NEXTAUTH_URL="http://127.0.0.1:3000"
